# Your Bluesky handle, without the leading @ (e.g. peark.es)
BSKY_HANDLE=

# A Bluesky APP PASSWORD — not your main password.
# Create one at: https://bsky.app/settings/app-passwords
BSKY_APP_PASSWORD=

# Optional: your PDS host. Leave blank for bsky.social-hosted accounts.
# Only set this if you self-host or use a third-party PDS.
# BSKY_PDS=https://bsky.social
